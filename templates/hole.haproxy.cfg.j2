defaults
    timeout connect         10s
    timeout client          1m
    timeout server          1m
    timeout tunnel 2147483647ms

frontend https
   bind 0.0.0.0:443
   mode tcp
   tcp-request inspect-delay 5s
   timeout client 300s
   tcp-request content accept if { req_ssl_hello_type 1 }

   use_backend telemt if { req_ssl_sni -i {{ mtproto_camouflage_domain }} }
   use_backend camouflage_backend if { req_ssl_sni -i {{ primary_domain }} }

   default_backend remnanode

frontend http_camouflage
    bind 0.0.0.0:80
    mode http

   http-request return status 403 content-type "text/html; charset=utf-8" file /web/403.html if !{ path -i / }
   http-request return status 200 content-type "text/html; charset=utf-8" file /web/index.html if { path -i / }

backend remnanode
   mode tcp
   option ssl-hello-chk
   server remnanode remnanode:443

backend telemt
   mode tcp
   option ssl-hello-chk
   server telemt telemt:8889

backend camouflage_backend
    mode tcp
    server local_http 127.0.0.1:8443

frontend camouflage
   bind 127.0.0.1:8443 ssl crt /usr/local/etc/haproxy/certificates/ strict-sni alpn h2,http/1.1
   mode http

   http-request return status 403 content-type "text/html; charset=utf-8" file /web/403.html if !{ path -i / }
   http-request return status 200 content-type "text/html; charset=utf-8" file /web/index.html if { path -i / }

