version: "3.8"
services:
  gateway:
    image: "haproxy:3.0.4-alpine"
    restart: "always"
    container_name: gateway
    volumes:
    - ./gateway/haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro
    - ./certs:/usr/local/etc/haproxy/certificates:ro
    ports:
    - "443:443"
    user: root
    depends_on:
      - remnawave
      - remnawave-subscription-page
{% if enable_ruleset_manager | default(true) | bool %}
      - ruleset-manager
{% endif %}
{% if enable_config_distributor | default(true) | bool %}
      - config-distributor
{% endif %}

  remnawave-db:
    image: postgres:17.5
    container_name: 'remnawave-db'
    hostname: remnawave-db
    restart: always
    environment:
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - POSTGRES_DB=${POSTGRES_DB}
      - TZ=UTC
    ports:
      - '127.0.0.1:6767:5432'
    volumes:
      - remnawave-db-data:/var/lib/postgresql/data
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}']
      interval: 3s
      timeout: 10s
      retries: 3

  remnawave:
    image: remnawave/backend:2.2.6
    container_name: 'remnawave'
    hostname: remnawave
    restart: always
    env_file: remnawave.env
    healthcheck:
      test: ['CMD-SHELL', 'curl -f http://localhost:${METRICS_PORT:-3001}/health']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    depends_on:
      remnawave-db:
        condition: service_healthy
      remnawave-redis:
        condition: service_healthy


  remnawave-redis:
    image: valkey/valkey:8.0.2-alpine
    container_name: remnawave-redis
    hostname: remnawave-redis
    restart: always
    volumes:
      - remnawave-redis-data:/data
    healthcheck:
      test: ['CMD', 'valkey-cli', 'ping']
      interval: 3s
      timeout: 10s
      retries: 3

  remnawave-subscription-page:
      image: remnawave/subscription-page:6.1.0
      container_name: remnawave-subscription-page
      hostname: remnawave-subscription-page
      restart: always
      environment:
        - REMNAWAVE_PANEL_URL=${REMNAWAVE_PANEL_URL}
        - CUSTOM_SUB_PREFIX=subscriptions
        - APP_PORT=3001
        - META_TITLE="Subscriptions"
        - META_DESCRIPTION="Subscription Page Description"

{% if enable_ruleset_manager | default(true) | bool %}
  ruleset-manager:
    image: asgardvpn/ruleset-manager:latest
    restart: always
    container_name: ruleset-manager
    volumes:
      - ./ruleset-manager.yml:/opt/asgard/ruleset-manager.yml:ro
      - rulesets:/usr/local/share/rulesets
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

{% endif %}
{% if enable_config_distributor | default(true) | bool %}
  config-distributor:
    image: asgardvpn/config-distributor:v3.2.0
    restart: always
    container_name: config-distributor
    volumes:
      - ./config-distributor.yml:/opt/asgard/config-distributor.yml:ro
      - ./templates:/opt/asgard/templates:ro
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

{% endif %}
volumes:
  remnawave-db-data:
    driver: local
    external: false
    name: remnawave-db-data
  remnawave-redis-data:
    driver: local
    external: false
    name: remnawave-redis-data
{% if enable_ruleset_manager | default(true) | bool %}
  rulesets:
    driver: local
    external: false
    name: rulesets
{% endif %}
