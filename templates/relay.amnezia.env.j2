# AmneziaWG Docker Server Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# SERVER SETTINGS
# ============================================================================

# AmneziaWG interface name
AWG_INTERFACE=awg0

# UDP listening port (51820 default, use 443 or 53 to mimic HTTPS/DNS)
AWG_PORT={{ amnezia_port }}

# VPN internal network
AWG_NET=10.13.13.0/24

# Server IP in VPN network
AWG_SERVER_IP=10.13.13.1

# DNS servers for clients (comma-separated)
AWG_DNS=8.8.8.8,8.8.4.4

# ============================================================================
# PUBLIC IP DETECTION
# ============================================================================

# Server public IP for client configurations
# Options:
#   auto - auto-detect using external services (recommended)
#   <IP> - specify IP manually
SERVER_PUBLIC_IP={{ primary_domain }}

# ============================================================================
# CLIENT SETTINGS
# ============================================================================

# Client subnet (usually same as AWG_NET)
CLIENTS_SUBNET=10.13.13.0/24

# Allowed IPs for routing through VPN
# 0.0.0.0/0 - all traffic through VPN
# 192.168.1.0/24 - only specific network
ALLOWED_IPS=0.0.0.0/0

# ============================================================================
# OBFUSCATION PARAMETERS (DPI BYPASS)
# ============================================================================
# These parameters are randomly generated on first 'make init'
# They help bypass Deep Packet Inspection systems

# Jc: Junk packet count (3-10)
AWG_JC={{ awg_jc | default(7) }}

# Jmin/Jmax: Junk packet size range (bytes)
AWG_JMIN={{ awg_jmin | default(50) }}
AWG_JMAX={{ awg_jmax | default(1000) }}

# S1/S2: Junk data size for init/response packets (15-150)
# Constraint: S1 + 56 != S2 (ensures different packet sizes)
AWG_S1={{ awg_s1 | default(86) }}
AWG_S2={{ awg_s2 | default(574) }}

# S3/S4 (AWG 2.0): Additional padding sizes
# S3: Cookie Reply padding, S4: Transport Data padding
# Keep 0 for legacy behavior compatibility
AWG_S3={{ awg_s3 | default(0) }}
AWG_S4={{ awg_s4 | default(0) }}

# H1-H4: Magic header values
# Supported formats:
#   - Single value: 991285757
#   - Range value (AWG 2.0): 991285757-991285857
# Ranges must not overlap between H1, H2, H3 and H4
# Single values remain fully supported for backward compatibility
AWG_H1={{ awg_h1 | default('471800590-471800690') }}
AWG_H2={{ awg_h2 | default('1246894907-1246895000') }}
AWG_H3={{ awg_h3 | default('923637689-923637690') }}
AWG_H4={{ awg_h4 | default('1769581055-1869581055') }}

# I1-I5 (AWG 2.0): Signature packets in CPS format
# Leave empty to preserve AWG 1.x behavior (no signature packets)
AWG_I1={{ awg_i1 | default('<b 0xc700000001><rc 8><t><r 100>') }}
AWG_I2={{ awg_i2 | default('<b 0xf6ab3267fa><t><rc 20><r 80>') }}
AWG_I3={{ awg_i3 | default('') }}
AWG_I4={{ awg_i4 | default('') }}
AWG_I5={{ awg_i5 | default('') }}

# ============================================================================
# ALTERNATIVE SETTINGS FOR STRICT DPI
# ============================================================================
# If default settings don't bypass blocks, try:
#
# Enhanced obfuscation:
# AWG_JC=12
# AWG_JMIN=75
# AWG_JMAX=1500
# AWG_S1=96
# AWG_S2=684
#
# DNS mimicking (port 53):
# AWG_PORT=53
# AWG_JC=5
# AWG_JMIN=32
# AWG_JMAX=512
#
# HTTPS mimicking (port 443):
# AWG_PORT=443
# AWG_S1=86
# AWG_S2=574
#
# AWG 2.0 example:
# AWG_S3=32
# AWG_S4=16
# AWG_H1=471800590-471800690
# AWG_H2=1246894907-1246895000
# AWG_H3=923637689-923637690
# AWG_H4=1769581055-1869581055
# AWG_I1=<b 0xc700000001><rc 8><t><r 100>

# ============================================================================
# BACKUP SETTINGS
# ============================================================================

# Backup interval for scheduled backup service (e.g., 24h, 12h, 1h)
BACKUP_INTERVAL=24h

# Number of backups to keep
BACKUP_KEEP=10

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Disable iptables (for CI/CD or restricted environments)
# WARNING: NAT and routing must be configured on host if disabled
# AWG_DISABLE_IPTABLES=false

# Health check timeout (seconds)
# HEALTHCHECK_TIMEOUT=5

# Verbose health check logging
# HEALTHCHECK_VERBOSE=false
