services:
{% if enable_ocserv | default(true) | bool %}
    gateway:
        image: "haproxy:3.0.4-alpine"
        container_name: gateway
        restart: "always"
        volumes:
        - ./gateway/haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro
        - ./fallback:/web:ro
        ports:
        - "443:443/tcp"
        user: root

{% endif %}
    remnanode:
        container_name: remnanode
        hostname: remnanode
        image: remnawave/node:2.2.3
        restart: always
        ports:
            - "0.0.0.0:${NODE_PORT}:${NODE_PORT}"
{% if enable_ocserv | default(true) | bool %}
            # 443 handled by gateway
{% else %}
            - "443:443"
{% endif %}
        env_file:
            - .env
        volumes:
            - './geo/geoip_RU.dat:/usr/local/share/xray/geoip_RU.dat'
            - './geo/geosite_RU.dat:/usr/local/share/xray/geosite_RU.dat'
            - '/var/log/remnanode:/var/log/remnanode'
            - './remnanode_certs:/etc/asgard_certs'

{% if enable_warp | default(true) | bool %}
    # published local port 1080
    warp:
        image: caomingjun/warp:2025.5.943.0-2.12.0
        container_name: warp
        restart: always
        device_cgroup_rules:
        - 'c 10:200 rwm'
        environment:
        - WARP_SLEEP=2
        cap_add:
        - MKNOD
        - AUDIT_WRITE
        - NET_ADMIN
        sysctls:
        - net.ipv6.conf.all.disable_ipv6=0
        - net.ipv4.conf.all.src_valid_mark=1
        volumes:
        - warp_config:/var/lib/cloudflare-warp

{% endif %}
{% if enable_sing_box | default(true) | bool %}
    sing-box:
        image: ghcr.io/sagernet/sing-box:v1.12.13
        container_name: sing-box
        restart: always
        volumes:
            - ./sing-box:/etc/sing-box
            - /etc/letsencrypt:/opt/asgard/certs:ro
        ports:
            - "${HYSTERIA_PORT}:8443/udp"
            - "${TUIC_PORT}:${TUIC_PORT}/udp"
            - "${SS_PORT}:${SS_PORT}/tcp"
            - "${SS_PORT}:${SS_PORT}/udp"
        command: -D /var/lib/sing-box -c /etc/sing-box/config.json run

{% endif %}
{% if enable_ocserv | default(true) | bool %}
    ocserv:
        image: quay.io/aminvakil/ocserv:1.3.0
        restart: always
        container_name: ocserv
        hostname: ${OCSERV_DOMAIN}
        ports:
        - "0.0.0.0:443:443/udp"
        volumes:
        - "./ocserv/config/ocserv.conf:/etc/ocserv/ocserv.conf:ro"
        - "./ocserv/certs:/etc/ocserv/certs:ro"
        - "./ocserv/users/ocpasswd:/users/ocpasswd:ro"
        privileged: true
        sysctls:
        - net.ipv4.ip_forward=1
        cap_add:
        - NET_ADMIN
        security_opt:
        - no-new-privileges

{% endif %}
{% if enable_pingtunnel | default(true) | bool %}
    pingtunnel:
        image: esrrhs/pingtunnel:latest
        restart: always
        container_name: pingtunnel
        network_mode: host
        command: "./pingtunnel -type server -key ${PINGTUNNEL_KEY}"
        privileged: true

{% endif %}
{% if enable_amnezia | default(true) | bool %}
    amnezia:
        image: asgardvpn/amnezia:v1.0.0
        container_name: amnezia
        privileged: true
        env_file:
            - amnezia/amnezia.env
        cap_add:
            - NET_ADMIN
            - SYS_MODULE
        sysctls:
            - net.ipv4.ip_forward=1
            - net.ipv4.conf.all.src_valid_mark=1
        devices:
            - /dev/net/tun
        ports:
            - "${AMNEZIA_PORT}:${AMNEZIA_PORT}/udp"
        volumes:
            - ./amnezia/config:/app/config
            - ./amnezia/clients:/app/clients
            - /lib/modules:/lib/modules:ro
        restart: always
        healthcheck:
            test: ["CMD", "/app/scripts/healthcheck.sh"]
            interval: 30s
            timeout: 15s
            start_period: 60s
            retries: 3

{% endif %}
{% if enable_node_agent | default(true) | bool %}
    node-agent:
        image: asgardvpn/node-agent:v1.2.0
        container_name: node-agent
        restart: always
        volumes:
            - ./node-agent.yaml:/opt/asgard/node-agent.yaml:ro
            - /var/run/docker.sock:/var/run/docker.sock
{% if enable_sing_box | default(true) | bool %}
            - ./sing-box/config.json:/etc/sing-box/config.json:rw
{% endif %}
{% if enable_ocserv | default(true) | bool %}
            - ./ocserv/users/ocpasswd:/etc/ocserv/ocpasswd:rw
{% endif %}
{% if enable_amnezia | default(true) | bool %}
            - ./amnezia/clients:/etc/amnezia/clients:ro
{% endif %}
{% endif %}
volumes:
{% if enable_warp | default(true) | bool %}
    warp_config:
{% endif %}
    mtproto_config: {}
