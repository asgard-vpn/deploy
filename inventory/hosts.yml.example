# Скопируйте этот файл в hosts.yml и настройте под свою инфраструктуру
# cp inventory/hosts.yml.example inventory/hosts.yml
#
# Переменные групп вынесены в group_vars/ (all, main, relays, relay_minimal, tgproxy).
# Для переопределения значений создайте или отредактируйте файлы в group_vars/.

main:
  hosts:
    main-server-01:
      ansible_host: 192.168.1.10
      ansible_user: admin
      ansible_port: 1122
      ansible_password: "{{ asgard_main_password }}"
      ansible_sudo_pass: "{{ asgard_main_password }}"
      primary_domain: main.example.com
      subscription_domain: sub.example.com
      assets_domain: assets.example.com
      public_domains:
        - "{{ primary_domain }}"
        - "{{ subscription_domain }}"
        - "{{ assets_domain }}"
  # Переменные группы main — см. group_vars/main.yml

relays:
  hosts:
    relay-server-01:
      ansible_host: 192.168.1.20
      ansible_user: admin
      ansible_port: 1122
      ansible_password: "{{ asgard_relay_password }}"
      ansible_sudo_pass: "{{ asgard_relay_password }}"
      primary_domain: relay1.example.com
      ocserv_domain: ocserv1.example.com
      # ocserv_exclude_users: []  # опционально: юзеры с ручными записями в ocpasswd (не генерировать)
      public_domains:
        - "{{ primary_domain }}"
        - "{{ ocserv_domain }}"
    # relay-server-02:
    #   ansible_host: 192.168.1.21
    #   ...
  children:
    # Минимальные relay (ex-hole): только remnanode, без доп. сервисов.
    # group_vars/relay_minimal.yml отключает все enable_*
    relay_minimal:
      hosts:
        hole-server-01:
          ansible_host: 192.168.1.40
          ansible_user: admin
          ansible_port: 1122
          ansible_password: "{{ asgard_relay_password }}"
          ansible_sudo_pass: "{{ asgard_relay_password }}"
          primary_domain: hole1.example.com
          ocserv_domain: "{{ primary_domain }}"
          public_domains:
            - "{{ primary_domain }}"
  # Переменные: group_vars/relays.yml, relay_minimal — group_vars/relay_minimal.yml

tgproxy:
  hosts:
    tgproxy-server-01:
      ansible_host: 192.168.1.30
      ansible_user: admin
      ansible_port: 1122
      ansible_password: "{{ asgard_relay_password }}"
      ansible_sudo_pass: "{{ asgard_relay_password }}"
      primary_domain: tgproxy1.example.com
      mtproto_camouflage_domain: www.example.org
      mtproto_secret: "{{ mtproto_secret }}"
      self_steal: false
      public_domains:
        - "{{ primary_domain }}"
  # Переменные группы tgproxy — см. group_vars/tgproxy.yml
