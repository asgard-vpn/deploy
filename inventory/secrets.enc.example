# Пароли и секреты (шифруются через ansible-vault)
# Заполните значения и зашифруйте: ansible-vault encrypt inventory/secrets.enc

# Let's Encrypt (Certbot)
certbot_admin_email:        # email для уведомлений о сертификатах (например, admin@example.com)

# SSH/Sudo пароли для доступа к серверам
asgard_relay_password:       # пароль relay-серверов (SSH, sudo)
asgard_main_password:        # пароль main-сервера (SSH, sudo)

# MTProto (Telegram proxy)
mtproto_secret:              # секрет по умолчанию

# Remnawave
remnawave_auth_secret:       # секрет аутентификации
remnawave_api_secret:        # секрет API
remnawave_ssl_cert:         # SSL-сертификат (PEM)
remnawave_api_token:        # токен API

# Веб-админка
web_admin_password:         # пароль админ-панели

# Hysteria VPN
hysteria_password:          # пароль для Hysteria
hysteria_salamander_password:  # пароль для режима Salamander

# Внутренние токены
nodes_secret_token:         # токен для связи между нодами
webhook_secret:             # секрет для webhook-запросов

# OpenConnect (ocserv) - camouflage
ocserv_camouflage_secret:   # секрет для доступа к VPN через URL (например, https://domain.com/?mysecret)
ocserv_camouflage_realm:    # realm для HTTP-аутентификации (по умолчанию "Admin Panel")

# Shadowsocks
ss_password:                # пароль Shadowsocks

# PingTunnel
pingtunnel_key:             # ключ/пароль PingTunnel




